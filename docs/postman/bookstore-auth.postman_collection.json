{
  "info": {
    "name": "Bookstore - Auth & User & Address",
    "_postman_id": "bookstore-plan1-v0.1",
    "description": "Plan 1 (Scaffold + Auth) 的 13 个端点。导入 Postman / Apifox 后,先调 Register 或 Login 自动写入 accessToken / refreshToken,后续请求自动带 Authorization。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"hello123\",\n  \"phone\": \"13800000001\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account\": \"alice\",\n  \"password\": \"hello123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "GET /api/user/me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/user/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "me"]
            }
          }
        },
        {
          "name": "PUT /api/user/me",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/user/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "me"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"小明\",\n  \"gender\": 1\n}"
            }
          }
        },
        {
          "name": "PUT /api/user/me/password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/user/me/password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "me", "password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"hello123\",\n  \"newPassword\": \"hello456\"\n}"
            }
          }
        },
        {
          "name": "PUT /api/user/me/avatar",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/user/me/avatar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "me", "avatar"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"avatarKey\": \"avatars/1.jpg\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Address",
      "item": [
        {
          "name": "GET /api/address",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/address",
              "host": ["{{baseUrl}}"],
              "path": ["api", "address"]
            }
          }
        },
        {
          "name": "POST /api/address",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/address",
              "host": ["{{baseUrl}}"],
              "path": ["api", "address"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiver\": \"张三\",\n  \"phone\": \"13800000001\",\n  \"province\": \"浙江\",\n  \"city\": \"杭州\",\n  \"district\": \"西湖区\",\n  \"detailAddress\": \"文一西路 100 号\",\n  \"setDefault\": true\n}"
            }
          }
        },
        {
          "name": "PUT /api/address/{id}",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/address/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "address", "1"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiver\": \"张三\",\n  \"phone\": \"13800000002\",\n  \"province\": \"浙江\",\n  \"city\": \"杭州\",\n  \"district\": \"余杭区\",\n  \"detailAddress\": \"五常街道 200 号\"\n}"
            }
          }
        },
        {
          "name": "PUT /api/address/{id}/default",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/address/1/default",
              "host": ["{{baseUrl}}"],
              "path": ["api", "address", "1", "default"]
            }
          }
        },
        {
          "name": "DELETE /api/address/{id}",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/address/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "address", "1"]
            }
          }
        }
      ]
    }
  ]
}
